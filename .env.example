# ============================================================
# mEMP Environment Variables (Beispiel)
# Kopiere diese Datei nach .env und fuelle die Werte aus.
# ============================================================

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=debug
APP_ENV=dev

# --- API ---
API_PORT=3000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:3000

# --- Web ---
WEB_PORT=8080
VITE_API_BASE_URL=http://localhost:3000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=memp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=memp
DATABASE_URL=postgres://memp:change-me@localhost:5432/memp

# --- Redis / Queue ---
REDIS_URL=redis://localhost:6379

# --- Microsoft Entra ID (OIDC) ---
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:3000/auth/callback

# --- Microsoft Graph (Outlook / Teams / SharePoint) ---
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
SHAREPOINT_SITE_ID=

# --- JWT / Session ---
JWT_SECRET=change-me-to-long-random-string
SESSION_SECRET=change-me-to-long-random-string

# --- Object / Document Storage (S3-kompatibel, optional) ---
S3_ENDPOINT=
S3_BUCKET=memp-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central-1

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=memp-api

# --- LLM / AI (Phase 4, optional) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Power BI (optional) ---
POWERBI_WORKSPACE_ID=
POWERBI_DATASET_ID=
