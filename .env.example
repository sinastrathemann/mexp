# mEXP — Environment Reference
# Wird beim Hub-Onboarding automatisch aus dem Image gelesen.

# Auth-Modus: "hub" (Produktion, X-MSQ-Header-Pflicht) | "dev-bypass" (lokal)
AUTH_MODE=hub

# Verzeichnis für persistente JSON-Files (im Container: benanntes Volume)
MEXP_DATA_DIR=/app/data

# HTTP-Server
PORT=3000
HOST=0.0.0.0

# Zeitzone für Log-Timestamps und Terminberechnung
TZ=Europe/Berlin

# Log-Level: debug | info | warn | error
LOG_LEVEL=info

# Node-Umgebung (production erzwingt AUTH_MODE=hub Default)
NODE_ENV=production

# --- Personio (optional; Employee-Sync) ---
# Aus Personio Admin: Einstellungen → Integrationen → API-Zugangsdaten
PERSONIO_CLIENT_ID=
PERSONIO_CLIENT_SECRET=
PERSONIO_API_URL=https://api.personio.de/v1
