{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "APP_ENV": "dev",
    "NODE_ENV": "development"
  },
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm install:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run *)",
      "Bash(pnpm -r *)",
      "Bash(pnpm --filter *)",
      "Bash(npx biome *)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log:*)",
      "Bash(git branch)",
      "Bash(git show:*)",
      "Bash(docker compose *)",
      "Bash(docker ps)",
      "Bash(docker logs:*)"
    ],
    "deny": ["Bash(rm -rf /*)", "Bash(git push --force*)", "Bash(git reset --hard*)"]
  }
}
